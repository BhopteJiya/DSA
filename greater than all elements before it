
#include <iostream>
#include<vector>
using namespace std;

vector<int> func(vector<int>& arr){
    int maxi=arr[0];
     vector<int> res;
     res.push_back(arr[0]);
    
    for(int i=0;i<arr.size();i++){
        if(arr[i]>maxi){
            res.push_back(arr[i]);
            maxi=arr[i];
        }
    }
    return res;
    
}

int main() {
    vector<int> arr = {16, 17, 4, 23, 5, 12};
    vector<int> ans = func(arr);

    for (int x : ans)
        cout << x << " ";

    return 0;
} 
