

#include <iostream>
using namespace std ;


int main()
{
    int n,m;
    cout<<"n, m : ";
    cin>>n>>m;
    int matrix[n][m];
    int rowindex=-1;
    int maxi=0;
    
    
    for(int i=1;i<=n;i++){
        int cnt=0;
        
        for(int j=0;j<m;j++){
            cout<<"enter ele : ";
            cin>>matrix[i][j];
            if(matrix[i][j]==1){
                cnt++;
            }
        }
        if(maxi<cnt){
            maxi=cnt;
            rowindex=i;
        }
    }
     
     cout<<maxi<<" ones in the row no.: "<<rowindex;
    
    return 0;
}
